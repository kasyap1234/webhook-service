# Webhook Service — Environment Configuration
# Copy this file to .env and adjust as needed.

# HTTP server port (optional, defaults to 8080)
PORT=8080

# PostgreSQL connection string
# Format: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://webhook:webhooksecret@localhost:5432/webhookdb?sslmode=disable

# RabbitMQ AMQP connection string
# Format: amqp://user:password@host:port/
RABBITMQ_URL=amqp://webhook:rabbitsecret@localhost:5672/
